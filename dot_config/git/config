[core]
    editor = nvim
    sshCommand = "ssh -i ${HOME}/.ssh/${HOSTNAME}_github"

[init]
    defaultBranch = main

[commit]
    gpgsign = true

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

[push]
    autoSetupRemote = true

[rerere]
    enable = true
    autoUpdate = true
